# ────────────────────────────────────────────────────────────────
# Intelli-Credit — .gitignore
# ────────────────────────────────────────────────────────────────

# Secrets — NEVER commit these
.env
*.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
venv/
.venv/
env/
.eggs/
*.egg-info/
dist/
*.egg
.mypy_cache/
.ruff_cache/

# Local databases
*.db
*.sqlite
*.sqlite3

# Uploaded / generated files (use S3 in prod)
uploads/
outputs/

# Node
node_modules/
frontend/dist/
frontend/.turbo/
.pnp/
.pnp.js

# Build / IDE
.next/
.vercel/
.vscode/
.idea/
*.suo
*.user
.DS_Store
Thumbs.db

# Celery / Redis
celerybeat-schedule
celerybeat.pid

# Logs
*.log
logs/

# Coverage
.coverage
htmlcov/
