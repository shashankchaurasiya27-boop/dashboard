# ────────────────────────────────────────────────────────────────
# Intelli-Credit — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is in .gitignore.
# ────────────────────────────────────────────────────────────────

# ──── Database ───────────────────────────────────────────────────
# LOCAL DEVELOPMENT (default — SQLite auto-created):
DATABASE_URL=sqlite:///./credit_app.db

# CLOUD DEPLOYMENT — replace with your cloud DB connection string:
# Neon    → postgresql+psycopg2://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Supabase → postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DATABASE_URL=postgresql+psycopg2://user:password@host/dbname?sslmode=require


# ──── CORS — Required in production ──────────────────────────────
# Comma-separated list of frontend origins (no trailing slash).
# Development default is http://localhost:5173 — set this for prod.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-domain.com


# ──── Gemini / Google AI ─────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Set to "true" to use the LLM-based financial extractor.
# Falls back to regex extraction if LLM fails or this is "false".
USE_LLM_EXTRACTOR=false


# ──── News API ───────────────────────────────────────────────────
# Free tier available at: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here


# ──── JWT Authentication ─────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-to-a-secure-random-secret
JWT_EXPIRE_MINS=60


# ──── AWS S3 (Optional — for cloud PDF storage) ──────────────────
# Leave blank to use local file storage.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=


# ──── Celery / Redis (for async background workers) ──────────────
# Local: install Redis and run `redis-server` before starting Celery.
# Cloud: get a connection string from Render, Railway, or Upstash.
REDIS_URL=redis://localhost:6379/0


# ──── Credit Bureau / CIBIL ──────────────────────────────────────
# Leave blank to use a deterministic mock score (great for demos).
CIBIL_API_KEY=
